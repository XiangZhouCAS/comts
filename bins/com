script_type="$1"
shift
if [ $# -eq 0 ]; then
    set -- "-h"
fi
case "$script_type" in
    ribo)
        Rscript "$R_SCRIPTS_DIR/ribo_rpkm.r" "$@"
        ;;
    res)
        Rscript "$R_SCRIPTS_DIR/ribo_rpkm2com.r" "$@"
        ;;
    *)
        Rscript "$R_SCRIPTS_DIR/comts_rpkm.help.r" "$@"
        exit 1
        ;;
esac
